<?xml version="1.0" encoding="UTF-8"?>
<!-- Zigbee2MQTT Bridge Plugin - MenuItems.xml -->
<MenuItems>
    <MenuItem id="discoverCreateDevices">
        <Name>Discover &amp; Create Devices</Name>
        <CallbackMethod>discover_create_devices</CallbackMethod>
    </MenuItem>
    <MenuItem id="sep1" isSeparator="true"/>
    <MenuItem id="createCoordinatorDevices">
        <Name>Create Coordinator Devices</Name>
        <CallbackMethod>create_coordinator_devices</CallbackMethod>
    </MenuItem>
    <MenuItem id="sepCoord" isSeparator="true"/>
    <MenuItem id="refreshBridgeDevices">
        <Name>Refresh Device List from MQTT</Name>
        <CallbackMethod>refresh_bridge_devices</CallbackMethod>
    </MenuItem>
    <MenuItem id="refreshDeviceCapabilities">
        <Name>Refresh Device Capabilities</Name>
        <CallbackMethod>refresh_device_capabilities</CallbackMethod>
    </MenuItem>
    <MenuItem id="reportOrphanedDevices">
        <Name>Report Orphaned Devices</Name>
        <CallbackMethod>report_orphaned_devices</CallbackMethod>
    </MenuItem>
    <MenuItem id="sepJoin" isSeparator="true"/>
    <MenuItem id="permitJoinEnable">
        <Name>Enable Pairing (Permit Join, 254s)</Name>
        <CallbackMethod>permit_join_enable</CallbackMethod>
    </MenuItem>
    <MenuItem id="permitJoinDisable">
        <Name>Disable Pairing (Permit Join Off)</Name>
        <CallbackMethod>permit_join_disable</CallbackMethod>
    </MenuItem>
    <MenuItem id="sep2" isSeparator="true"/>
    <MenuItem id="toggleTimestamps">
        <Name>Toggle Timestamps in Log (on/off)</Name>
        <CallbackMethod>menuToggleTimestamps</CallbackMethod>
    </MenuItem>
    <MenuItem id="sep3" isSeparator="true"/>
    <MenuItem id="testMqttConnection">
        <Name>Test MQTT Connection</Name>
        <CallbackMethod>testMqttConnection</CallbackMethod>
    </MenuItem>
    <MenuItem id="showPluginInfo">
        <Name>Show Plugin Info</Name>
        <CallbackMethod>showPluginInfo</CallbackMethod>
    </MenuItem>
</MenuItems>
