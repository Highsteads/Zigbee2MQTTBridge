<?xml version="1.0" encoding="UTF-8"?>
<!-- Zigbee2MQTT Bridge Plugin - Devices.xml -->
<!-- Device types auto-detected from zigbee2mqtt exposes array:               -->
<!--   z2mLight            : dimmer  — bulbs, LED strips, colour lights        -->
<!--   z2mRelay            : relay   — switches, outlets, smart plugs          -->
<!--   z2mContactSensor    : sensor  — door/window contact (open/closed)       -->
<!--   z2mOccupancySensor  : sensor  — PIR / mmWave presence (detected/clear)  -->
<!--   z2mWaterLeakSensor  : sensor  — water/flood alarm (leak/OK)             -->
<!--   z2mTemperatureSensor: sensor  — environmental (temp/humidity/pressure)  -->
<!--   z2mSensor           : sensor  — catch-all for mixed/unknown types       -->
<!--   z2mRepeater         : relay   — signal repeaters/routers (online/offline)-->
<!--   z2mCover            : dimmer  — blinds, shutters, covers                -->
<!--   z2mButton           : sensor  — button/scene controllers (action events) -->
<Devices>

    <!-- ================================================================
         z2mLight — Zigbee light device (dimmer class)
         Native states: onOffState, brightnessLevel
         Optional native: redLevel/greenLevel/blueLevel (SupportsColor=true)
                          whiteTemperature (SupportsWhiteTemperature=true)
         ================================================================ -->
    <Device type="dimmer" id="z2mLight" subType="indigo.kDimmerDeviceSubType.Dimmer">
        <Name>Z2M Light</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly (e.g. Living Room Bulb)</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <!-- Hidden capability flags — set by auto-create -->
            <Field id="has_brightness"  type="checkbox" hidden="true" defaultValue="true"/>
            <Field id="has_color_temp"  type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_color"       type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState, brightnessLevel: native dimmer states — not declared here -->
            <State id="colorMode">
                <ValueType>String</ValueType>
                <TriggerLabel>Color Mode Changed</TriggerLabel>
                <ControlPageLabel>Color Mode</ControlPageLabel>
            </State>
            <State id="colorTemp">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Color Temp Changed</TriggerLabel>
                <ControlPageLabel>Color Temp K</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ================================================================
         z2mRelay — Zigbee relay/switch/outlet (relay class)
         Native states: onOffState
         ================================================================ -->
    <Device type="relay" id="z2mRelay" subType="indigo.kRelayDeviceSubType.Outlet">
        <Name>Z2M Relay</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly (e.g. Kitchen Switch)</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <!-- Hidden capability flags -->
            <Field id="has_power"  type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_energy" type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState: native relay state — not declared here -->
            <State id="power">
                <ValueType>Float</ValueType>
                <TriggerLabel>Power Changed</TriggerLabel>
                <ControlPageLabel>Power W</ControlPageLabel>
            </State>
            <State id="energy">
                <ValueType>Float</ValueType>
                <TriggerLabel>Energy Changed</TriggerLabel>
                <ControlPageLabel>Energy kWh</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ================================================================
         z2mSensor — Zigbee sensor (sensor class)
         Native states: onOffState, sensorValue
         onOffState assignment priority: waterLeak > occupancy > contact
         sensorValue priority: temperature > illuminance > humidity > pressure
         ================================================================ -->
    <Device type="sensor" id="z2mSensor">
        <Name>Z2M Sensor</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly (e.g. Front Door Sensor)</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <!-- Hidden sensor capability flags -->
            <Field id="has_temperature" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_humidity"    type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_contact"     type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_occupancy"   type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_water_leak"  type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_battery"     type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_pressure"    type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_illuminance" type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState, sensorValue: native sensor states — not declared here -->
            <State id="temperature">
                <ValueType>Float</ValueType>
                <TriggerLabel>Temperature Changed</TriggerLabel>
                <ControlPageLabel>Temperature</ControlPageLabel>
            </State>
            <State id="humidity">
                <ValueType>Float</ValueType>
                <TriggerLabel>Humidity Changed</TriggerLabel>
                <ControlPageLabel>Humidity %</ControlPageLabel>
            </State>
            <State id="contact">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Contact Changed</TriggerLabel>
                <ControlPageLabel>Contact</ControlPageLabel>
            </State>
            <State id="motion">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Motion Changed</TriggerLabel>
                <ControlPageLabel>Motion</ControlPageLabel>
            </State>
            <State id="waterLeak">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Water Leak Changed</TriggerLabel>
                <ControlPageLabel>Water Leak</ControlPageLabel>
            </State>
            <State id="battery">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Battery Changed</TriggerLabel>
                <ControlPageLabel>Battery %</ControlPageLabel>
            </State>
            <State id="pressure">
                <ValueType>Float</ValueType>
                <TriggerLabel>Pressure Changed</TriggerLabel>
                <ControlPageLabel>Pressure hPa</ControlPageLabel>
            </State>
            <State id="illuminance">
                <ValueType>Float</ValueType>
                <TriggerLabel>Illuminance Changed</TriggerLabel>
                <ControlPageLabel>Illuminance lux</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ================================================================
         z2mContactSensor — Zigbee door/window contact sensor (sensor class)
         onOffState: True = open, False = closed
         ================================================================ -->
    <Device type="sensor" id="z2mContactSensor" subType="indigo.kSensorDeviceSubType.DoorWindow">
        <Name>Z2M Contact Sensor</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <Field id="has_battery" type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState: native sensor state (True=open, False=closed) — not declared here -->
            <State id="contact">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Contact Changed</TriggerLabel>
                <ControlPageLabel>Contact (closed=true)</ControlPageLabel>
            </State>
            <State id="battery">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Battery Changed</TriggerLabel>
                <ControlPageLabel>Battery %</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ================================================================
         z2mOccupancySensor — Zigbee PIR / mmWave occupancy sensor (sensor class)
         onOffState: True = any detection (PIR OR mmWave), False = clear
         occupancy : raw PIR trigger (fast, momentary)
         presence  : raw mmWave detection (slow, persistent)
         motion    : combined — True if either occupancy OR presence is True
         ================================================================ -->
    <Device type="sensor" id="z2mOccupancySensor" subType="indigo.kSensorDeviceSubType.Motion">
        <Name>Z2M Occupancy Sensor</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <Field id="has_battery"     type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_pir"         type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_presence"    type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_illuminance" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_temperature" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_humidity"    type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState: native sensor state (True=detected, False=clear) — not declared here -->
            <State id="motion">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Motion (combined) Changed</TriggerLabel>
                <ControlPageLabel>Motion (PIR or mmWave)</ControlPageLabel>
            </State>
            <State id="occupancy">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>PIR Occupancy Changed</TriggerLabel>
                <ControlPageLabel>PIR Occupancy</ControlPageLabel>
            </State>
            <State id="presence">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>mmWave Presence Changed</TriggerLabel>
                <ControlPageLabel>mmWave Presence</ControlPageLabel>
            </State>
            <State id="illuminance">
                <ValueType>Float</ValueType>
                <TriggerLabel>Illuminance Changed</TriggerLabel>
                <ControlPageLabel>Illuminance lux</ControlPageLabel>
            </State>
            <State id="temperature">
                <ValueType>Float</ValueType>
                <TriggerLabel>Temperature Changed</TriggerLabel>
                <ControlPageLabel>Temperature</ControlPageLabel>
            </State>
            <State id="humidity">
                <ValueType>Float</ValueType>
                <TriggerLabel>Humidity Changed</TriggerLabel>
                <ControlPageLabel>Humidity %</ControlPageLabel>
            </State>
            <State id="battery">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Battery Changed</TriggerLabel>
                <ControlPageLabel>Battery %</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ================================================================
         z2mWaterLeakSensor — Zigbee water/flood sensor (sensor class)
         onOffState: True = leak detected, False = OK
         ================================================================ -->
    <Device type="sensor" id="z2mWaterLeakSensor">
        <Name>Z2M Water Leak Sensor</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <Field id="has_battery"     type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_temperature" type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState: native sensor state (True=leak, False=OK) — not declared here -->
            <State id="waterLeak">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Water Leak Changed</TriggerLabel>
                <ControlPageLabel>Water Leak</ControlPageLabel>
            </State>
            <State id="temperature">
                <ValueType>Float</ValueType>
                <TriggerLabel>Temperature Changed</TriggerLabel>
                <ControlPageLabel>Temperature</ControlPageLabel>
            </State>
            <State id="battery">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Battery Changed</TriggerLabel>
                <ControlPageLabel>Battery %</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ================================================================
         z2mTemperatureSensor — Zigbee environmental sensor (sensor class)
         Reports temperature, humidity, pressure, illuminance (any combo).
         No binary alarm states — onOffState is not meaningful (stays False).
         ================================================================ -->
    <Device type="sensor" id="z2mTemperatureSensor" subType="indigo.kSensorDeviceSubType.Temperature">
        <Name>Z2M Temperature Sensor</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <Field id="has_battery"     type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_temperature" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_humidity"    type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_pressure"    type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="has_illuminance" type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <State id="temperature">
                <ValueType>Float</ValueType>
                <TriggerLabel>Temperature Changed</TriggerLabel>
                <ControlPageLabel>Temperature C</ControlPageLabel>
            </State>
            <State id="humidity">
                <ValueType>Float</ValueType>
                <TriggerLabel>Humidity Changed</TriggerLabel>
                <ControlPageLabel>Humidity %</ControlPageLabel>
            </State>
            <State id="pressure">
                <ValueType>Float</ValueType>
                <TriggerLabel>Pressure Changed</TriggerLabel>
                <ControlPageLabel>Pressure hPa</ControlPageLabel>
            </State>
            <State id="illuminance">
                <ValueType>Float</ValueType>
                <TriggerLabel>Illuminance Changed</TriggerLabel>
                <ControlPageLabel>Illuminance lux</ControlPageLabel>
            </State>
            <State id="battery">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Battery Changed</TriggerLabel>
                <ControlPageLabel>Battery %</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
        <UiDisplayStateId>temperature</UiDisplayStateId>
    </Device>

    <!-- ================================================================
         z2mRepeater — Zigbee signal repeater/router (relay class)
         onOffState: True = online, False = offline (driven by availability)
         No sensor states — repeaters only relay signals and report link quality.
         ================================================================ -->
    <Device type="relay" id="z2mRepeater">
        <Name>Z2M Repeater</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
        </ConfigUI>
        <States>
            <!-- onOffState: native relay state (True=online, False=offline) — not declared here -->
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ================================================================
         z2mCover — Zigbee cover/blind/shutter (dimmer class)
         brightnessLevel maps to position (0=closed, 100=open)
         onOffState: True=open (position>0), False=closed (position=0)
         Commands use OPEN/CLOSE/STOP (not ON/OFF)
         ================================================================ -->
    <Device type="dimmer" id="z2mCover" subType="indigo.kDimmerDeviceSubType.Blind">
        <Name>Z2M Cover</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly (e.g. Living Room Blind)</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <Field id="has_tilt" type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState, brightnessLevel: native dimmer states — not declared here -->
            <State id="coverState">
                <ValueType>String</ValueType>
                <TriggerLabel>Cover State Changed</TriggerLabel>
                <ControlPageLabel>Cover State</ControlPageLabel>
            </State>
            <State id="tiltAngle">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Tilt Angle Changed</TriggerLabel>
                <ControlPageLabel>Tilt</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
    </Device>


    <!-- ================================================================
         z2mButton — Zigbee button / scene controller (sensor class)
         Fires stateless action events (e.g. "1_single", "2_double").
         lastAction  : most recent action string from zigbee2mqtt
         lastButton  : numeric button index extracted from action (1, 2, ...)
         pressCount  : increments on every press — use this state in Indigo
                       triggers to guarantee firing even on repeated same-button presses
         onOffState  : True on any press (may not change on back-to-back presses;
                       use pressCount changed trigger instead for reliability)
         ================================================================ -->
    <Device type="sensor" id="z2mButton">
        <Name>Z2M Button / Scene</Name>
        <ConfigUI>
            <Field id="friendly_name" type="textfield" defaultValue="">
                <Label>Friendly Name:</Label>
                <Description>zigbee2mqtt friendly_name — must match exactly (e.g. Hall Switch)</Description>
            </Field>
            <Field id="ieee_address" type="textfield" readonly="true" defaultValue="">
                <Label>IEEE Address:</Label>
            </Field>
            <Field id="vendor" type="textfield" readonly="true" defaultValue="">
                <Label>Vendor:</Label>
            </Field>
            <Field id="model" type="textfield" readonly="true" defaultValue="">
                <Label>Model:</Label>
            </Field>
            <Field id="capabilities_display" type="textfield" readonly="true" defaultValue="">
                <Label>Capabilities:</Label>
            </Field>
            <Field id="has_battery" type="checkbox" hidden="true" defaultValue="false"/>
        </ConfigUI>
        <States>
            <!-- onOffState: native sensor state (True=pressed) — not declared here -->
            <State id="lastAction">
                <ValueType>String</ValueType>
                <TriggerLabel>Button Action Changed</TriggerLabel>
                <ControlPageLabel>Last Action</ControlPageLabel>
            </State>
            <State id="lastButton">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Last Button Changed</TriggerLabel>
                <ControlPageLabel>Last Button</ControlPageLabel>
            </State>
            <State id="pressCount">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Press Count Changed</TriggerLabel>
                <ControlPageLabel>Press Count</ControlPageLabel>
            </State>
            <State id="battery">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Battery Changed</TriggerLabel>
                <ControlPageLabel>Battery %</ControlPageLabel>
            </State>
            <State id="availability">
                <ValueType>String</ValueType>
                <TriggerLabel>Availability Changed</TriggerLabel>
                <ControlPageLabel>Availability</ControlPageLabel>
            </State>
            <State id="linkQuality">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Link Quality Changed</TriggerLabel>
                <ControlPageLabel>Link Quality</ControlPageLabel>
            </State>
        </States>
        <UiDisplayStateId>lastAction</UiDisplayStateId>
    </Device>

    <!-- ================================================================
         z2mCoordinator — Z2M bridge itself (custom device class)
         One per MQTT prefix (e.g. zigbee2mqtt + zigbee2mqtt_garage).
         Aggregates bridge/state, bridge/info and bridge/devices into a single
         Indigo device so the bridge can be triggered on / shown on control
         pages without scraping the underlying MQTT messages each time.
         ================================================================ -->
    <Device type="custom" id="z2mCoordinator">
        <Name>Z2M Coordinator</Name>
        <ConfigUI>
            <Field id="mqtt_prefix" type="textfield" defaultValue="zigbee2mqtt">
                <Label>MQTT Prefix:</Label>
                <Description>Z2M topic prefix this coordinator represents (e.g. zigbee2mqtt, zigbee2mqtt_garage). Must match a prefix configured in Plugin Preferences.</Description>
            </Field>
        </ConfigUI>
        <States>
            <State id="status">
                <ValueType>String</ValueType>
                <TriggerLabel>Bridge Status Changed</TriggerLabel>
                <ControlPageLabel>Status</ControlPageLabel>
            </State>
            <State id="version">
                <ValueType>String</ValueType>
                <TriggerLabel>Z2M Version Changed</TriggerLabel>
                <ControlPageLabel>Z2M Version</ControlPageLabel>
            </State>
            <State id="coordinator">
                <ValueType>String</ValueType>
                <TriggerLabel>Coordinator Type Changed</TriggerLabel>
                <ControlPageLabel>Coordinator Type</ControlPageLabel>
            </State>
            <State id="permitJoin">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Permit Join Changed</TriggerLabel>
                <ControlPageLabel>Permit Join</ControlPageLabel>
            </State>
            <State id="permitJoinEnd">
                <ValueType>String</ValueType>
                <TriggerLabel>Permit Join End Changed</TriggerLabel>
                <ControlPageLabel>Permit Join End</ControlPageLabel>
            </State>
            <State id="networkChannel">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Network Channel Changed</TriggerLabel>
                <ControlPageLabel>Network Channel</ControlPageLabel>
            </State>
            <State id="panId">
                <ValueType>Integer</ValueType>
                <TriggerLabel>PAN ID Changed</TriggerLabel>
                <ControlPageLabel>PAN ID</ControlPageLabel>
            </State>
            <State id="extendedPanId">
                <ValueType>String</ValueType>
                <TriggerLabel>Extended PAN ID Changed</TriggerLabel>
                <ControlPageLabel>Extended PAN ID</ControlPageLabel>
            </State>
            <State id="deviceCount">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Device Count Changed</TriggerLabel>
                <ControlPageLabel>Device Count</ControlPageLabel>
            </State>
            <State id="restartRequired">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Restart Required Changed</TriggerLabel>
                <ControlPageLabel>Restart Required</ControlPageLabel>
            </State>
            <State id="logLevel">
                <ValueType>String</ValueType>
                <TriggerLabel>Log Level Changed</TriggerLabel>
                <ControlPageLabel>Log Level</ControlPageLabel>
            </State>
            <State id="lastUpdate">
                <ValueType>String</ValueType>
                <TriggerLabel>Last Update Changed</TriggerLabel>
                <ControlPageLabel>Last Update</ControlPageLabel>
            </State>
        </States>
        <UiDisplayStateId>status</UiDisplayStateId>
    </Device>

</Devices>
